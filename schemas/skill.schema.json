{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rigorloop.dev/schemas/skill.schema.json",
  "title": "RigorLoop Skill Metadata",
  "description": "First-release machine-readable shape for per-skill metadata only.",
  "type": "object",
  "required": [
    "name",
    "description"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true
}
