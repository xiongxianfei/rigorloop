{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rigorloop.dev/schemas/change.schema.json",
  "title": "RigorLoop Change Metadata",
  "description": "First-release machine-readable traceability for non-trivial changes.",
  "type": "object",
  "required": [
    "change_id",
    "title",
    "classification",
    "risk",
    "artifacts",
    "requirements",
    "tests",
    "validation",
    "changed_files",
    "review"
  ],
  "properties": {
    "change_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "classification": {
      "type": "string",
      "minLength": 1
    },
    "risk": {
      "type": "string",
      "minLength": 1
    },
    "artifacts": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "requirements": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "tests": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "validation": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "command",
          "result"
        ],
        "properties": {
          "command": {
            "type": "string",
            "minLength": 1
          },
          "result": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": true
      }
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "review": {
      "type": "object",
      "required": [
        "status",
        "unresolved_items"
      ],
      "properties": {
        "status": {
          "type": "string",
          "minLength": 1
        },
        "unresolved_items": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    "workflow": {
      "type": "object",
      "properties": {
        "autoprogression": {
          "type": "object",
          "properties": {
            "profile": {
              "type": "string",
              "enum": [
                "off",
                "authoring-through-plan-review",
                "implementation-through-verify"
              ]
            },
            "authoring_through_plan_review": {
              "type": "object",
              "required": [
                "profile",
                "authorized_by",
                "authorized_at",
                "change_id"
              ],
              "properties": {
                "profile": {
                  "type": "string",
                  "enum": [
                    "authoring-through-plan-review"
                  ]
                },
                "authorized_by": {
                  "type": "string",
                  "minLength": 1
                },
                "authorized_at": {
                  "type": "string",
                  "minLength": 1
                },
                "change_id": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "additionalProperties": true
            },
            "implementation_through_verify": {
              "type": "object",
              "required": [
                "profile",
                "phase",
                "state",
                "authorized_by",
                "authorized_at",
                "change_id"
              ],
              "properties": {
                "profile": {
                  "type": "string",
                  "enum": [
                    "implementation-through-verify"
                  ]
                },
                "phase": {
                  "type": "string",
                  "enum": [
                    "A",
                    "B",
                    "C"
                  ]
                },
                "state": {
                  "type": "string",
                  "enum": [
                    "off",
                    "armed",
                    "active",
                    "paused",
                    "completed",
                    "cancelled"
                  ]
                },
                "authorized_by": {
                  "type": "string",
                  "minLength": 1
                },
                "authorized_at": {
                  "type": "string",
                  "minLength": 1
                },
                "change_id": {
                  "type": "string",
                  "minLength": 1
                },
                "activation_baseline": {
                  "type": "string",
                  "minLength": 1
                },
                "cancellation": {
                  "type": "object",
                  "properties": {
                    "cancelled_by": {
                      "type": "string",
                      "minLength": 1
                    },
                    "cancelled_at": {
                      "type": "string",
                      "minLength": 1
                    },
                    "reason": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "additionalProperties": true
                }
              },
              "additionalProperties": true
            },
            "authorized_by": {
              "type": "string",
              "minLength": 1
            },
            "authorized_at": {
              "type": "string",
              "minLength": 1
            },
            "change_id": {
              "type": "string",
              "minLength": 1
            },
            "state": {
              "type": "string",
              "minLength": 1
            },
            "phase": {
              "type": "string",
              "minLength": 1
            },
            "request": {
              "type": "string",
              "minLength": 1
            },
            "activation_baseline": {
              "type": "string",
              "minLength": 1
            },
            "persistence_status": {
              "type": "string",
              "minLength": 1
            },
            "session_intent": {
              "type": "boolean"
            },
            "fallback_policy_path": {
              "type": "string",
              "minLength": 1
            },
            "cancellation": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
